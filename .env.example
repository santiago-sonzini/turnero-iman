# Copiá este archivo a ".env" y completá lo que uses.
# La demo usa la misma persistencia real y se carga con `npm run db:seed`.

# ── Base de datos (deploy real) ─────────────────────────────────────────────
# DATABASE_URL="postgresql://usuario:password@localhost:5432/iman"

# ── Auth y storage (Supabase, opcional) ─────────────────────────────────────
# Sin esto: no hay login (la demo entra directa) y las imágenes se guardan en
# public/uploads/ del propio server (requiere filesystem persistente).
# SUPABASE_URL="https://xxxx.supabase.co"
# SUPABASE_ANON_KEY="..."

# ── SaaS multi-tenant: Mercado Pago Suscripciones ───────────────────────────
# SANDBOX PRIMERO — OJO: las credenciales TEST-... NO sirven para Suscripciones
# (solo Checkout API/Bricks; /preapproval devuelve 500). Para probar hay que
# usar el access token de PRODUCCIÓN (APP_USR-...) de una CUENTA DE PRUEBA
# vendedor: crear los usuarios de prueba en el panel, loguearse en
# mercadopago.com.ar/developers COMO el vendedor de prueba, crear ahí una app
# y usar sus credenciales. Pagar con el comprador de prueba + tarjetas de
# prueba. Recién pasar a producción cuando todo el ciclo
# (autorizar → cobro → rechazo → cancelar) esté validado.
# MP_ACCESS_TOKEN="APP_USR-... (del vendedor de prueba en sandbox)"
# Firma secreta del panel de Webhooks (valida el header x-signature).
# Configurar la URL {NEXT_PUBLIC_APP_URL}/api/mp/webhook con los eventos:
# subscription_preapproval, subscription_authorized_payment, payment.
# MP_WEBHOOK_SECRET="..."
# URL pública de la app (back_url de MP y links absolutos).
# NEXT_PUBLIC_APP_URL="https://app.iman.ar"

# ── Worker Turnos Auto (open-wa, opcional) ─────────────────────────────────
# Proceso persistente y aislado. Sin él, el producto funciona con wa.me.
# WA_SERVER_URL="http://localhost:8321"
# WA_SERVER_TOKEN="un-token-largo-igual-al-del-wa-server"
# En el entorno DEL WORKER:
# IMAN_CORE_URL="http://localhost:3000"
# WA_SESSION_ROOT="./sessions"
# WA_MIN_GAP_MS="25000"
# WA_MAX_GAP_MS="70000"


# ── Email marketing (SMTP opcional) ─────────────────────────────────────────
# Sin esto, la pestaña Email usa mailto: (abre tu cliente de correo con el
# mensaje listo). Con SMTP se puede enviar directo desde la app.
# SMTP_USER="tunegocio@gmail.com"
# SMTP_PASS="contraseña-de-aplicacion"
