# Copiá este archivo a ".env" y completá lo que uses.
# La demo usa la misma persistencia real y se carga con `npm run db:seed`.

# ── Base de datos (deploy real) ─────────────────────────────────────────────
DATABASE_URL="postgresql://usuario:password@localhost:5432/iman"
# Con Supabase: DATABASE_URL suele ser el pooler y DIRECT_URL la conexión directa.
DIRECT_URL="postgresql://usuario:password@localhost:5432/iman"

# ── Auth y storage (Supabase, opcional) ─────────────────────────────────────
# Sin esto: en producción no hay login; el usuario demo existe solo en dev.
# SUPABASE_URL="https://xxxx.supabase.co"
# SUPABASE_ANON_KEY="..."

# ── SaaS multi-tenant: Mercado Pago Suscripciones ───────────────────────────
# SANDBOX PRIMERO — OJO: las credenciales TEST-... NO sirven para Suscripciones
# (solo Checkout API/Bricks). Para probar suscripciones hay que
# usar el access token de PRODUCCIÓN (APP_USR-...) de una CUENTA DE PRUEBA
# vendedor: crear los usuarios de prueba en el panel, loguearse en
# mercadopago.com.ar/developers COMO el vendedor de prueba, crear ahí una app
# y usar sus credenciales. Pagar con el comprador de prueba + tarjetas de
# prueba. Recién pasar a producción cuando todo el ciclo
# (autorizar → cobro → rechazo → cancelar) esté validado.
# MP_ACCESS_TOKEN="APP_USR-... (del vendedor de prueba en sandbox)"
# Firma secreta del panel de Webhooks (valida el header x-signature).
# Configurar la URL {NEXT_PUBLIC_APP_URL}/api/mp/webhook con los eventos:
# subscription_preapproval, subscription_authorized_payment, payment.
# MP_WEBHOOK_SECRET="..."
# Secreto bearer para la reconciliación diaria de suscripciones en Vercel.
# CRON_SECRET="otro-secreto-largo"
# NOTA: usamos un preapproval_plan compartido por tier y creamos una preapproval
# individual por tenant antes del checkout. En sandbox, el email de la cuenta
# debe pertenecer al comprador de prueba de Mercado Pago.
# URL pública de la app (back_url de MP y links absolutos).
# OBLIGATORIA para MP: /preapproval exige back_url y rechaza localhost, así
# que sin esta URL https el checkout queda deshabilitado (en dev usá un túnel
# tipo ngrok/cloudflared o la URL del deploy de Vercel para probarlo).
# La suscripción se crea con free_trial nativo de MP: autorizás hoy y el
# primer débito llega recién al terminar los 7 días de prueba.
# NEXT_PUBLIC_APP_URL="https://app.iman.ar"

# ── Worker Turnos Pro (WhatsApp Web, opcional) ─────────────────────────────
# Proceso persistente y aislado. Sin él, el producto funciona con wa.me.
# WA_SERVER_URL="http://localhost:8321"
# WA_SERVER_TOKEN="un-token-largo-igual-al-del-wa-server"
# En el entorno DEL WORKER:
# IMAN_CORE_URL="http://localhost:3000"
# WA_SESSION_ROOT="./sessions"
# WA_MIN_GAP_MS="25000"
# WA_MAX_GAP_MS="70000"


# Sal aleatoria para hashear identificadores usados por rate limiting.
# En producción: al menos 16 caracteres y distinta de otros secretos.
# RATE_LIMIT_SALT="cambia-esto-por-un-valor-largo"

# ── Email transaccional (SMTP) ──────────────────────────────────────────────
# Emails de la app: bienvenida al suscribirse, confirmación al cliente y aviso
# de reserva al dueño. Recomendado: Brevo (smtp-relay.brevo.com:587). SMTP_FROM
# DEBE ser un remitente/dominio VERIFICADO en el proveedor (si no, lo rechaza).
# SMTP_HOST="smtp-relay.brevo.com"
# SMTP_PORT="587"
# SMTP_USER="xxxxx@smtp-brevo.com"
# SMTP_PASS="..."
# SMTP_FROM="turnos@tudominio.com"      # remitente verificado
# SMTP_FROM_NAME="Imán Turnos"
ADMIN_EMAILS="santisonzini1234@gmail.com"
