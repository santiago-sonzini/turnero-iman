generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
}

// Plan de suscripción de MP COMPARTIDO por tier (plantilla creada una sola vez;
// todos los tenants suscriben sobre el mismo). Antes se creaba un plan por
// tenant, lo cual ensuciaba la cuenta de MP y era conceptualmente al revés.
model MpPlan {
  mpPlanId String @id
  tier PlanTier @unique
  amountArs Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
enum PlanTier {
  TURNOS
  TURNOS_AUTO
}
enum SubscriptionStatus {
  ONBOARDING
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
}
enum AppointmentStatus {
  CONFIRMADO
  ASISTIO
  NO_VINO
  CANCELADO
}
enum BookingChannel {
  OWNER
  PUBLIC
  PROMO
}
enum PromotionKind {
  ADD_ON
  DESCUENTO
  PRECIO_FIJO
}
enum MessageKind {
  CONFIRMACION
  RECORDATORIO
  CICLO
  HUECO
}
enum MessageStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  FALLBACK
}
enum WhatsappHealth {
  DISCONNECTED
  QR_PENDING
  CONNECTED
  DEGRADED
  BANNED
}

model Tenant {
  id String @id @default(cuid())
  name String
  slug String @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  plan PlanTier?
  planStatus SubscriptionStatus @default(ONBOARDING)
  trialEndsAt DateTime?
  graceUntil DateTime?
  mpPreapprovalId String? @unique
  mpPreapprovalPlanId String? @unique
  mpPayerEmail String?
  mpLastPaymentAt DateTime?
  addons String[] @default([])
  onboardingStep String @default("negocio")
  revealSnapshot Json?
  whatsappRiskAcceptedAt DateTime?
  whatsappRiskAcceptedBy String?
  users User[]
  profile BusinessProfile?
  clients Client[]
  services Service[]
  workingHours WorkingHour[]
  appointments Appointment[]
  promotions Promotion[]
  messageJobs MessageJob[]
  whatsappSession WhatsappSession?
  funnelEvents FunnelEvent[]
  @@index([planStatus])
}

model User {
  id String @id
  email String @unique
  phone String?
  name String?
  role Role @default(ADMIN)
  tenantId String
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([tenantId])
}

model BusinessProfile {
  id String @id @default(cuid())
  tenantId String @unique
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name String
  description String?
  businessType String?
  address String?
  mapsUrl String?
  phone String?
  instagram String?
  timezone String @default("America/Argentina/Buenos_Aires")
  accent String @default("#E94F37")
  bookingLeadMinutes Int @default(60)
  bookingHorizonDays Int @default(30)
  slotStepMinutes Int @default(15)
  bufferMinutes Int @default(0)
  depositsEnabled Boolean @default(false)
  showPrices Boolean @default(true)
  vacations Json?
  cancelWindowHours Int @default(48)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id String @id @default(cuid())
  tenantId String
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name String
  description String?
  emoji String @default("✂️")
  durationMinutes Int
  priceCents Int
  active Boolean @default(true)
  sortOrder Int @default(0)
  appointments Appointment[]
  promotions Promotion[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([tenantId, name])
  @@index([tenantId, active])
}

model WorkingHour {
  id String @id @default(cuid())
  tenantId String
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  weekday Int
  startMinutes Int
  endMinutes Int
  active Boolean @default(true)
  @@unique([tenantId, weekday, startMinutes])
  @@index([tenantId, weekday])
}

model Client {
  id String @id @default(cuid())
  tenantId String
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phone String
  name String
  email String?
  notes String?
  expectedCycleDays Int?
  marketingConsent Boolean @default(false)
  accessToken String? @unique
  appointments Appointment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([tenantId, phone])
  @@index([tenantId, name])
}

model Appointment {
  id String @id @default(cuid())
  tenantId String
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceId String
  service Service @relation(fields: [serviceId], references: [id])
  clientId String
  client Client @relation(fields: [clientId], references: [id])
  startsAt DateTime @db.Timestamptz(3)
  endsAt DateTime @db.Timestamptz(3)
  status AppointmentStatus @default(CONFIRMADO)
  channel BookingChannel @default(OWNER)
  notes String?
  depositRequired Boolean @default(false)
  depositAmountCents Int?
  depositStatus String?
  promotionId String?
  promotion Promotion? @relation(fields: [promotionId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([tenantId, startsAt])
  @@index([tenantId, clientId, status])
}

model Promotion {
  id String @id @default(cuid())
  tenantId String
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceId String?
  service Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  name String
  kind PromotionKind @default(ADD_ON)
  valueCents Int?
  addOnLabel String?
  message String
  token String @unique @default(cuid())
  expiresAt DateTime
  active Boolean @default(true)
  appointments Appointment[]
  createdAt DateTime @default(now())
  @@index([tenantId, active, expiresAt])
}

model MessageJob {
  id String @id @default(cuid())
  tenantId String
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kind MessageKind
  status MessageStatus @default(PENDING)
  phone String
  body String
  scheduledAt DateTime
  attempts Int @default(0)
  nextAttemptAt DateTime?
  lastError String?
  sentAt DateTime?
  idempotencyKey String @unique
  createdAt DateTime @default(now())
  @@index([status, scheduledAt])
  @@index([tenantId, createdAt])
}

model WhatsappSession {
  id String @id @default(cuid())
  tenantId String @unique
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  health WhatsappHealth @default(DISCONNECTED)
  phone String?
  qrCode String?
  lastSeenAt DateTime?
  lastError String?
  updatedAt DateTime @updatedAt
}

model FunnelEvent {
  id String @id @default(cuid())
  tenantId String
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  event String
  props Json?
  createdAt DateTime @default(now())
  @@index([event, createdAt])
  @@index([tenantId])
}
